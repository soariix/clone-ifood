# ─── Appium ───────────────────────────────────────────────────────────────────
# URL do servidor Appium (padrão: http://127.0.0.1:4723)
APPIUM_URL=http://127.0.0.1:4723

# Caminho absoluto para o APK gerado pelo Expo (ex: eas build local)
APK_PATH=/caminho/para/o/app.apk

# ─── API do backend ───────────────────────────────────────────────────────────
# URL base do servidor Express (padrão: http://localhost:3333)
API_BASE_URL=http://localhost:3333

# ─── Credenciais de teste ─────────────────────────────────────────────────────
TEST_EMAIL=test@ifood.com
TEST_PASSWORD=123456
