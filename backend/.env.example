# Variáveis de ambiente do backend
# Copie para .env e preencha os valores reais

# ─── Banco de Dados ────────────────────────────────────────────────────────────
# PostgreSQL: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ifood_clone"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="troque-por-uma-string-longa-e-aleatoria-em-producao"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3333
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Para desenvolvimento com Expo, pode deixar * ou especificar:
# ALLOWED_ORIGINS=http://localhost:8081,exp://192.168.x.x:8081
